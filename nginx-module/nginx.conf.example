load_module modules/ngx_http_x_cache_key_filter_module.so;

worker_processes 1;

events {
    worker_connections 1024;
}

http {
    proxy_cache_path /tmp/nginx-cache
                     levels=1:2
                     keys_zone=cdn_cache:10m
                     max_size=100m
                     inactive=10m
                     use_temp_path=off;

    server {
        listen 8080;

        location / {
            proxy_cache cdn_cache;
            proxy_cache_valid 200 1m;
            proxy_pass http://127.0.0.1:9000;
        }
    }
}
